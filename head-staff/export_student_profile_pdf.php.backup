<?php
session_start();
require_once '../config/database.php';

// Authentication check - allow head, admin, and director
if (!isset($_SESSION['logged_in']) || !in_array($_SESSION['user_role'], ['head', 'admin', 'director'])) {
    header('Location: ../index.php');
    exit();
}

// Get student ID from query parameter
$student_id = $_GET['student_id'] ?? null;

if (!$student_id) {
    die('Student ID is required');
}

$pdo = getDBConnection();

try {
    // Get student data from student_artists table
    $stmt = $pdo->prepare("SELECT * FROM student_artists WHERE id = ?");
    $stmt->execute([$student_id]);
    $app = $stmt->fetch(PDO::FETCH_ASSOC);

    if (!$app) {
        die('Student profile not found');
    }

    // Fetch participation records from student_participation_records
    $stmt = $pdo->prepare("SELECT participation_date as date, event_name, participation_level as level, rank_award FROM student_participation_records WHERE student_id = ? ORDER BY participation_date DESC");
    $stmt->execute([$app['id']]);
    $participations = $stmt->fetchAll(PDO::FETCH_ASSOC);

    // Fetch competition records from student_competition_records
    $stmt = $pdo->prepare("SELECT competition_date as date, event_name, competition_level as level, rank_award FROM student_competition_records WHERE student_id = ? ORDER BY competition_date DESC");
    $stmt->execute([$app['id']]);
    $competitions = $stmt->fetchAll(PDO::FETCH_ASSOC);

    // Merge participation and competition records (same structure)
    $allParticipations = array_merge($participations, $competitions);
    // Sort by date descending
    usort($allParticipations, function($a, $b) {
        return strtotime($b['date']) - strtotime($a['date']);
    });

    // Fetch affiliation records from student_affiliation_records
    $stmt = $pdo->prepare("SELECT position, organization, years_active FROM student_affiliation_records WHERE student_id = ? ORDER BY created_at DESC");
    $stmt->execute([$app['id']]);
    $affiliations = $stmt->fetchAll(PDO::FETCH_ASSOC);

    // Get assigned cultural group first (authoritative for export)
    $assigned_cultural_group = trim((string)($app['cultural_group'] ?? ''));

    // Get original performance type from latest application (fallback only)
    $application_performance_type = '';
    if (!empty($app['sr_code'])) {
      $stmt = $pdo->prepare("SELECT performance_type FROM applications WHERE sr_code = ? ORDER BY id DESC LIMIT 1");
      $stmt->execute([$app['sr_code']]);
      $latestApplication = $stmt->fetch(PDO::FETCH_ASSOC);
      $application_performance_type = trim((string)($latestApplication['performance_type'] ?? ''));
    }

    $performance_type = '';
    $performance_line_value = '';

    $groupToTypeMap = [
      'dulaang batangan' => 'Theater',
      'batstateu dance company' => 'Dance',
      'diwayanis dance theatre' => 'Dance',
      'batstateu band' => 'Music',
      'indak yaman dance varsity' => 'Dance',
      'ritmo voice' => 'Music',
      'sandugo dance group' => 'Dance',
      'areglo band' => 'Music',
      'teatro aliwana' => 'Theater',
      'the levites' => 'Music',
      'melophiles' => 'Music',
      'sindayog' => 'Dance'
    ];

    if ($assigned_cultural_group !== '') {
      $performance_line_value = $assigned_cultural_group;
      $groupKey = strtolower($assigned_cultural_group);
      $performance_type = $groupToTypeMap[$groupKey] ?? '';

      if ($performance_type === '') {
        if (stripos($assigned_cultural_group, 'dance') !== false || stripos($assigned_cultural_group, 'indak') !== false) {
          $performance_type = 'Dance';
        } elseif (stripos($assigned_cultural_group, 'band') !== false || stripos($assigned_cultural_group, 'voice') !== false || stripos($assigned_cultural_group, 'melo') !== false || stripos($assigned_cultural_group, 'levites') !== false) {
          $performance_type = 'Music';
        } elseif (stripos($assigned_cultural_group, 'teatro') !== false || stripos($assigned_cultural_group, 'theater') !== false || stripos($assigned_cultural_group, 'dulaang') !== false) {
          $performance_type = 'Theater';
        } else {
          $performance_type = 'Performing Arts';
        }
      }
    } elseif ($application_performance_type !== '') {
      $performance_line_value = $application_performance_type;
      if (preg_match('/^\s*([^:]+)\s*:\s*(.+)\s*$/', $application_performance_type, $matches)) {
        $typeToken = strtolower(trim(str_replace(['-', ' '], '_', $matches[1])));
        $typeMap = [
          'performing_arts' => 'Performing Arts',
          'music' => 'Music',
          'dance' => 'Dance',
          'theater' => 'Theater',
          'visual_arts' => 'Visual Arts',
          'literary_arts' => 'Literary Arts'
        ];
        if (isset($typeMap[$typeToken])) {
          $performance_type = $typeMap[$typeToken];
          $performance_line_value = trim($matches[2]);
        }
      }
    }

} catch (Exception $e) {
    die('Error fetching profile data: ' . $e->getMessage());
}

// Helper function to safely escape HTML
function escapeHtml($value) {
    return htmlspecialchars($value ?? '', ENT_QUOTES, 'UTF-8');
}

// Helper function to check if performance type matches
function isPerformanceType($current, $type) {
    if (empty($current)) return false;
    return stripos($current, $type) !== false;
}

// Prepare data variables
$fullName = trim(($app['first_name'] ?? '') . ' ' . ($app['middle_name'] ?? '') . ' ' . ($app['last_name'] ?? ''));
$address = $app['address'] ?? $app['permanent_address'] ?? '';
$presentAddress = $app['present_address'] ?? '';
$dateOfBirth = $app['date_of_birth'] ?? '';
$age = $app['age'] ?? '';
$gender = $app['gender'] ?? '';
$placeOfBirth = $app['place_of_birth'] ?? '';
$email = $app['email'] ?? '';
$contactNumber = $app['contact_number'] ?? '';
$fatherName = $app['father_name'] ?? '';
$motherName = $app['mother_name'] ?? '';
$guardian = ($app['guardian'] && $app['guardian'] != 'N/A') ? $app['guardian'] : '';
$parentGuardianContact = $app['guardian_contact'] ?? $app['emergency_contact_number'] ?? '';

$campus = $app['campus'] ?? '';
$srCode = $app['sr_code'] ?? '';
$yearLevel = $app['year_level'] ?? '';
$college = $app['college'] ?? '';
$program = $app['program'] ?? '';

// Prepare photo URL
$photoUrl = '';
$photoPlaceholder = true;
if ($app['profile_photo'] && file_exists('../' . $app['profile_photo'])) {
    $photoUrl = '../' . $app['profile_photo'];
    $photoPlaceholder = false;
}

// Determine logo URL
$logoUrl = '';
$logoPaths = [
    '../assets/logo.jpg',
    '../assets/OCA Logo.png',
    '../assets/bsu.png',
    '../assets/bsu.jpg'
];
foreach ($logoPaths as $path) {
    if (file_exists($path)) {
        $logoUrl = $path;
        break;
    }
}

// Prepare achievements array (ensure minimum 9 rows)
$achievements = [];
for ($i = 0; $i < 9; $i++) {
    if (isset($allParticipations[$i])) {
        $achievements[] = [
            'date' => $allParticipations[$i]['date'] ?? '',
            'event' => $allParticipations[$i]['event_name'] ?? '',
            'level' => $allParticipations[$i]['level'] ?? '',
            'rank' => $allParticipations[$i]['rank_award'] ?? ''
        ];
    } else {
        $achievements[] = [
            'date' => '',
            'event' => '',
            'level' => '',
            'rank' => ''
        ];
    }
}

// Prepare affiliations array (ensure minimum 5 rows)
$affiliationsList = [];
for ($i = 0; $i < 5; $i++) {
    if (isset($affiliations[$i])) {
        $affiliationsList[] = [
            'position' => $affiliations[$i]['position'] ?? '',
            'organization' => $affiliations[$i]['organization'] ?? '',
            'years' => $affiliations[$i]['years_active'] ?? ''
        ];
    } else {
        $affiliationsList[] = [
            'position' => '',
            'organization' => '',
            'years' => ''
        ];
    }
}

// Current date for signature
$signatureDate = date('F d, Y');

